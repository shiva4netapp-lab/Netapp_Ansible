<!DOCTYPE html>
<html>
<head>
<title>NetApp ONTAP Health Check Report</title>

<style>
body {
    font-family: Arial, Helvetica, sans-serif;
    margin: 0;
    background: #f4f7fb;
    color: #1f2937;
}

.header {
    background: white;
    padding: 25px;
    border-bottom: 4px solid #0067b1;
}

.header h1 {
    margin: 0;
    color: #0067b1;
    font-size: 36px;
}

.header p {
    margin: 8px 0 0 0;
    font-size: 16px;
    color: #4b5563;
}

.summary {
    display: flex;
    gap: 20px;
    padding: 25px;
    flex-wrap: wrap;
}

.summary-card {
    background: white;
    border-left: 6px solid #00a3e0;
    border-radius: 8px;
    padding: 20px;
    min-width: 220px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.summary-card h3 {
    margin-top: 0;
    color: #0067b1;
}

.section {
    background: white;
    margin: 25px;
    padding: 20px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.section h2 {
    background: #0067b1;
    color: white;
    padding: 14px;
    border-radius: 5px;
    margin-top: 0;
}

.success {
    color: #16a34a;
    font-weight: bold;
}

.failed {
    color: #dc2626;
    font-weight: bold;
}

.warning {
    color: #d97706;
    font-weight: bold;
}

pre {
    background: #111827;
    color: #d1fae5;
    padding: 18px;
    border-radius: 6px;
    overflow-x: auto;
    white-space: pre-wrap;
    font-size: 14px;
    line-height: 1.5;
}

.command {
    background: #eef6ff;
    padding: 10px;
    border-left: 5px solid #0067b1;
    margin-bottom: 10px;
}

button {
    background: #0067b1;
    color: white;
    border: none;
    padding: 10px 16px;
    border-radius: 5px;
    cursor: pointer;
    margin-right: 8px;
}

button:hover {
    background: #004f87;
}
</style>

</head>

<body>

<div class="header">
    <h1>NetApp ONTAP Health Check Report</h1>
    <p>
        Cluster: {{ hostname }} |
        Report Type: HEALTH CHECK |
        Generated: {{ report_time }}
    </p>
    <br>
    <button onclick="window.print()">Print / Save PDF</button>
</div>

<div class="summary">
    <div class="summary-card">
        <h3>Cluster IP</h3>
        <p>{{ hostname }}</p>
    </div>

    <div class="summary-card">
        <h3>Total Checks</h3>
        <p>{{ ontap_results.results | length }}</p>
    </div>

    <div class="summary-card">
        <h3>Completed</h3>
        <p class="success">
            {{ ontap_results.results | selectattr('rc', 'equalto', 0) | list | length }}
        </p>
    </div>

    <div class="summary-card">
        <h3>Failed / Warning</h3>
        <p class="failed">
            {{ ontap_results.results | rejectattr('rc', 'equalto', 0) | list | length }}
        </p>
    </div>
</div>

{% for result in ontap_results.results %}

<div class="section">

    <h2>{{ result.item.tab }}</h2>

    <div class="command">
        <b>Command:</b> {{ result.item.command }}<br>
        <b>Status:</b>
        {% if result.rc == 0 %}
            <span class="success">SUCCESS</span>
        {% else %}
            <span class="warning">WARNING / CHECK REQUIRED</span>
        {% endif %}
    </div>

    <h3>Command Output</h3>

    {% if result.stdout is defined and result.stdout | length > 0 %}
        <pre>{{ result.stdout }}</pre>
    {% else %}
        <pre>No stdout output received.</pre>
    {% endif %}

    {% if result.stderr is defined and result.stderr | length > 0 %}
        <h3>SSH Warning / Error Output</h3>
        <pre>{{ result.stderr }}</pre>
    {% endif %}

</div>

{% endfor %}

</body>
</html>
