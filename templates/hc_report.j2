<body>

{% set total_checks = ontap_results.results | length %}
{% set cluster_error_ns = namespace(count=0) %}
{% set package_error_ns = namespace(count=0) %}
{% set total_error_ns = namespace(count=0) %}

{% for result in ontap_results.results %}
    {% set tab_error_ns = namespace(count=0) %}

    {% if result.rc != 0 %}
        {% set tab_error_ns.count = tab_error_ns.count + 1 %}
    {% endif %}

    {% if result.stdout_lines is defined %}
        {% for line in result.stdout_lines %}
            {% set l = line | lower %}
            {% if
                'false' in l or
                'fail' in l or
                'failed' in l or
                'error' in l or
                'offline' in l or
                'down' in l or
                'degraded' in l or
                'not-configured' in l or
                'unknown' in l or
                'unhealthy' in l
            %}
                {% set tab_error_ns.count = tab_error_ns.count + 1 %}
            {% endif %}
        {% endfor %}
    {% endif %}

    {% if result.stderr_lines is defined %}
        {% for line in result.stderr_lines %}
            {% set l = line | lower %}
            {% if
                'error' in l or
                'failed' in l or
                'not recognized' in l or
                'no route' in l or
                'permission denied' in l or
                'connection refused' in l
            %}
                {% set tab_error_ns.count = tab_error_ns.count + 1 %}
            {% endif %}
        {% endfor %}
    {% endif %}

    {% if result.item.tab == 'Package Validation' %}
        {% set package_error_ns.count = package_error_ns.count + tab_error_ns.count %}
    {% elif result.item.tab != 'SSH Command Output' %}
        {% set cluster_error_ns.count = cluster_error_ns.count + tab_error_ns.count %}
    {% endif %}

    {% if result.item.tab != 'SSH Command Output' %}
        {% set total_error_ns.count = total_error_ns.count + tab_error_ns.count %}
    {% endif %}
{% endfor %}

{% set failed_checks = cluster_error_ns.count %}
{% set package_failed_checks = package_error_ns.count %}
{% set total_failed_checks = total_error_ns.count %}
{% set failed_command_count = ontap_results.results | rejectattr('rc', 'equalto', 0) | list | length %}
{% set success_checks = total_checks - failed_command_count %}

<div class="header">
    <div class="header-left">
        <div class="logo-text">NetApp</div>

        <div class="report-title">
            <h1>NetApp ONTAP Health Check Report</h1>
            <p>
                Cluster: {{ hostname }} -- Type: HEALTH CHECK -- Timestamp: {{ report_time }}
            </p>
        </div>
    </div>

    <div class="header-buttons">
        <button onclick="window.print()">Print / Save PDF</button>
        <button onclick="showErrorsOnly()">Show Errors Only</button>
        <button onclick="showAll()">Show All</button>

        <label class="error-toggle">
            <input id="errorCheckBox" type="checkbox" onclick="toggleErrorsOnly()">
            Show errors only
        </label>
    </div>
</div>

<div class="global-search-panel">
    <h2>Global Search Criteria</h2>

    <div class="global-search-row">
        <input
            id="globalSearchInput"
            type="text"
            placeholder="Search across all command outputs. Example: Cluster01, 93%, offline, false, error"
            onkeyup="if(event.key === 'Enter'){ globalSearchAllCommands(); }">

        <button onclick="globalSearchAllCommands()">Search All Commands</button>
        <button onclick="clearGlobalSearch()">Clear</button>
    </div>

    <div class="quick-search-buttons">
        <button onclick="setGlobalSearch('error')">Error</button>
        <button onclick="setGlobalSearch('failed')">Failed</button>
        <button onclick="setGlobalSearch('false')">False</button>
        <button onclick="setGlobalSearch('offline')">Offline</button>
        <button onclick="setGlobalSearch('down')">Down</button>
        <button onclick="setGlobalSearch('not-configured')">Not Configured</button>
        <button onclick="setGlobalSearch('93%')">93%</button>
        <button onclick="setGlobalSearch('Cluster01')">Cluster01</button>
    </div>

    <div id="globalSearchResults" class="global-search-results"></div>
</div>

<div class="summary">
    <div class="summary-card">
        <h2>Cluster IP</h2>
        <p>{{ hostname }}</p>
    </div>

    <div class="summary-card">
        <h2>Total Checks</h2>
        <p>{{ total_checks }}</p>
    </div>

    <div class="summary-card">
        <h2>Completed</h2>
        <p class="pass-text">{{ success_checks }}</p>
    </div>

    <div class="summary-card">
        <h2>Error Count</h2>
        <p class="fail-text">{{ total_failed_checks }}</p>
    </div>
</div>

<div class="main-tabs-wrapper">
    <div class="main-tabs">
        <div id="btn-cluster_checks_panel" class="main-tab active" onclick="openMainTab('cluster_checks_panel')">
            ONTAP Cluster Checks
            {% if failed_checks > 0 %}
                <span class="big-error-badge">{{ failed_checks }}</span>
            {% endif %}
        </div>

        <div id="btn-package_panel" class="main-tab" data-error-count="{{ package_failed_checks }}" onclick="openMainTab('package_panel')">
            Package Validation
            {% if package_failed_checks > 0 %}
                <span class="big-error-badge">{{ package_failed_checks }}</span>
                <div class="error-popup">
                    <div class="popup-title">
                        Package Validation - {{ package_failed_checks }} issue(s)
                    </div>
                    <div class="popup-line">
                        Package validation requires review. Check package repository output.
                    </div>
                </div>
            {% endif %}
        </div>

        <div id="btn-ssh_panel" class="main-tab" onclick="openMainTab('ssh_panel')">
            SSH Command Output
        </div>
    </div>
</div>

<div id="cluster_checks_panel" class="main-panel active">

    <div class="tabs-wrapper">
        <div class="tabs">

            {% for result in ontap_results.results %}
                {% if result.item.tab not in ['Package Validation', 'SSH Command Output'] %}

                    {% set tab_id = result.item.tab | replace(' ', '_') | replace('/', '_') %}
                    {% set tab_error_ns = namespace(count=0, popup='') %}

                    {% if result.rc != 0 %}
                        {% set tab_error_ns.count = tab_error_ns.count + 1 %}
                        {% set tab_error_ns.popup = tab_error_ns.popup ~ 'Return code is ' ~ result.rc ~ '\n' %}
                    {% endif %}

                    {% if result.stdout_lines is defined %}
                        {% for line in result.stdout_lines %}
                            {% set l = line | lower %}
                            {% if
                                'false' in l or
                                'fail' in l or
                                'failed' in l or
                                'error' in l or
                                'offline' in l or
                                'down' in l or
                                'degraded' in l or
                                'not-configured' in l or
                                'unknown' in l or
                                'unhealthy' in l
                            %}
                                {% set tab_error_ns.count = tab_error_ns.count + 1 %}
                                {% set tab_error_ns.popup = tab_error_ns.popup ~ line ~ '\n' %}
                            {% endif %}
                        {% endfor %}
                    {% endif %}

                    {% if result.stderr_lines is defined %}
                        {% for line in result.stderr_lines %}
                            {% set l = line | lower %}
                            {% if
                                'error' in l or
                                'failed' in l or
                                'not recognized' in l or
                                'no route' in l or
                                'permission denied' in l or
                                'connection refused' in l
                            %}
                                {% set tab_error_ns.count = tab_error_ns.count + 1 %}
                                {% set tab_error_ns.popup = tab_error_ns.popup ~ line ~ '\n' %}
                            {% endif %}
                        {% endfor %}
                    {% endif %}

                    <button
                        id="btn-{{ tab_id }}"
                        class="tab-button"
                        onclick="openTab('{{ tab_id }}')">

                        {{ result.item.tab }}

                        {% if tab_error_ns.count > 0 %}
                            <span class="error-badge">{{ tab_error_ns.count }}</span>

                            <div class="error-popup">
                                <div class="popup-title">
                                    {{ result.item.tab }} - {{ tab_error_ns.count }} issue(s)
                                </div>

                                {% for popup_line in tab_error_ns.popup.split('\n') %}
                                    {% if popup_line | length > 0 %}
                                        <div class="popup-line">{{ popup_line }}</div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </button>

                {% endif %}
            {% endfor %}

        </div>
    </div>

    <div class="content">

        {% for result in ontap_results.results %}
            {% if result.item.tab not in ['Package Validation', 'SSH Command Output'] %}

                {% set tab_id = result.item.tab | replace(' ', '_') | replace('/', '_') %}
                {% set tab_error_ns = namespace(count=0) %}

                {% if result.rc != 0 %}
                    {% set tab_error_ns.count = tab_error_ns.count + 1 %}
                {% endif %}

                {% if result.stdout_lines is defined %}
                    {% for line in result.stdout_lines %}
                        {% set l = line | lower %}
                        {% if
                            'false' in l or
                            'fail' in l or
                            'failed' in l or
                            'error' in l or
                            'offline' in l or
                            'down' in l or
                            'degraded' in l or
                            'not-configured' in l or
                            'unknown' in l or
                            'unhealthy' in l
                        %}
                            {% set tab_error_ns.count = tab_error_ns.count + 1 %}
                        {% endif %}
                    {% endfor %}
                {% endif %}

                {% if result.stderr_lines is defined %}
                    {% for line in result.stderr_lines %}
                        {% set l = line | lower %}
                        {% if
                            'error' in l or
                            'failed' in l or
                            'not recognized' in l or
                            'no route' in l or
                            'permission denied' in l or
                            'connection refused' in l
                        %}
                            {% set tab_error_ns.count = tab_error_ns.count + 1 %}
                        {% endif %}
                    {% endfor %}
                {% endif %}

                <div
                    id="{{ tab_id }}"
                    class="tab-panel"
                    data-error-count="{{ tab_error_ns.count }}">

                    <div class="section-title">
                        {{ result.item.tab }}
                    </div>

                    <div class="card">
                        <h2>{{ result.item.tab }}</h2>

                        {% if tab_error_ns.count > 0 %}
                            <div class="status-info status-error">
                                Status: Review Required - {{ tab_error_ns.count }} Issue(s)
                            </div>
                        {% elif result.rc == 0 %}
                            <div class="status-info">
                                Status: Info
                            </div>
                        {% else %}
                            <div class="status-info status-warning">
                                Status: Warning
                            </div>
                        {% endif %}
                    </div>

                    <div class="card">
                        <h2>Error Criteria</h2>

                        <div class="criteria">
                            <ul>
                                {% for criteria in result.item.error_criteria %}
                                    <li>{{ criteria }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>

                    <div class="card">
                        <h2>Check Summary</h2>

                        <table class="table-like">
                            <tr>
                                <th>Check Category</th>
                                <th>Command</th>
                                <th>Status</th>
                                <th>Error Count</th>
                                <th>Return Code</th>
                            </tr>

                            <tr>
                                <td>{{ result.item.category }}</td>
                                <td>{{ result.item.command }}</td>
                                <td>
                                    {% if tab_error_ns.count > 0 %}
                                        <span class="status-badge status-review">REVIEW</span>
                                    {% elif result.rc == 0 %}
                                        <span class="status-badge status-success">SUCCESS</span>
                                    {% else %}
                                        <span class="status-badge status-warning">WARNING</span>
                                    {% endif %}
                                </td>
                                <td>{{ tab_error_ns.count }}</td>
                                <td>{{ result.rc }}</td>
                            </tr>
                        </table>
                    </div>

                    <div class="card">
                        <h2>Command Output</h2>

                        <div class="command-box">
                            <b>Executed Command:</b> {{ result.item.command }}
                        </div>

                        <div class="search-box">
                            <input
                                class="search-input"
                                type="text"
                                placeholder="Search output in this tab"
                                onkeyup="searchCurrentTab()">
                        </div>

                        <div class="command-header">
                            {{ hostname }}::&gt; {{ result.item.command }}
                        </div>

                        {% if result.stdout is defined and result.stdout | length > 0 %}
                            <pre class="output-box">{{ result.stdout }}</pre>
                        {% else %}
                            <pre class="output-box">No output received.</pre>
                        {% endif %}
                    </div>

                    {% if result.stderr is defined and result.stderr | length > 0 %}
                    <div class="card">
                        <h2>SSH Warning / Error Output</h2>
                        <pre class="error-output-box">{{ result.stderr }}</pre>
                    </div>
                    {% endif %}

                </div>

            {% endif %}
        {% endfor %}

    </div>
</div>

<div id="package_panel" class="main-panel">

    <div class="content">
        <div class="section-title">
            Upgrade Validation Report
        </div>

        <h1>Validation Reports After Download</h1>

        {% if package_failed_checks > 0 %}
            <div class="status-info status-error">
                Status: Review Required - {{ package_failed_checks }} Issue(s)
            </div>
        {% else %}
            <div class="status-info">
                Status: Info
            </div>
        {% endif %}

        <div class="card">
            <h2>Error Criteria</h2>
            <div class="criteria">
                <p><b><i>status</i></b> equals <b><i>error</i></b></p>
            </div>
        </div>

        <table class="validation-table">
            <tr>
                <th>Update Check</th>
                <th>Status</th>
                <th>Issue</th>
                <th>Action</th>
            </tr>

            <tr>
                <td>Manual checks</td>
                <td>warning</td>
                <td>
                    Manual validation checks need to be performed. Refer to the Upgrade Advisor Plan
                    or the "What should I verify before I upgrade with or without Upgrade Advisor"
                    section in the Upgrade ONTAP documentation.
                </td>
                <td>
                    Refer to the Upgrade Advisor Plan or NetApp ONTAP upgrade documentation
                    for remaining validation checks before update.
                </td>
            </tr>

            <tr>
                <td>ONTAP API deprecation check</td>
                <td>warning</td>
                <td>
                    NetApp ONTAP API usage should be reviewed before upgrade.
                </td>
                <td>
                    Transition automation tools from ONTAPI to ONTAP REST API where applicable.
                </td>
            </tr>

            <tr>
                <td>SAN compatibility</td>
                <td>warning</td>
                <td>
                    If SAN is configured, manually confirm full SAN compatibility.
                </td>
                <td>
                    Validate host OS, multipath, HBA drivers, firmware and Host Utilities.
                </td>
            </tr>

            {% for result in ontap_results.results %}
                {% if result.item.tab == 'Package Validation' %}
                <tr>
                    <td>Package Repository Check</td>
                    <td>{% if package_failed_checks > 0 %}error{% elif result.rc == 0 %}info{% else %}warning{% endif %}</td>
                    <td>
                        <pre style="white-space:pre-wrap; font-family:Consolas, monospace;">{{ result.stdout }}</pre>
                    </td>
                    <td>
                        Validate expected ONTAP package availability before upgrade.
                    </td>
                </tr>
                {% endif %}
            {% endfor %}
        </table>
    </div>
</div>

<div id="ssh_panel" class="main-panel">

    <div class="content">
        <h2><b>Cluster:</b> {{ hostname }}</h2>
        <h2><b>Check Type:</b> Pre-Checks</h2>
        <h2><b>Generated:</b> {{ report_time }}</h2>
        <h2><b>Total Commands:</b> {{ total_checks }}</h2>

        <hr style="border: 1px solid #1e90ff; margin: 35px 0;">

        {% for result in ontap_results.results %}
            <div class="command-header">
                {{ hostname }}::&gt; {{ result.item.command }}
            </div>

            {% if result.stdout is defined and result.stdout | length > 0 %}
                <pre class="output-box">{{ result.stdout }}</pre>
            {% else %}
                <pre class="output-box">No output received.</pre>
            {% endif %}
        {% endfor %}
    </div>
</div>

<div class="footer">
    Generated by Ansible Forms | NetApp ONTAP Health Check Report
</div>

</body>
</html>
