<!DOCTYPE html>
<html>
<head>
<title>NetApp Health Check Report</title>

<style>
body {
    font-family: Arial, Helvetica, sans-serif;
    margin: 0;
    background: #f4f7fb;
    color: #1f2937;
}

.header {
    background: white;
    padding: 20px;
    border-bottom: 3px solid #0067b1;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.header h1 {
    margin: 0;
    color: #0067b1;
}

.header-info {
    font-size: 14px;
    color: #4b5563;
}

.top-tabs {
    display: flex;
    background: #26384f;
    overflow-x: auto;
}

.top-tabs button {
    background: #26384f;
    color: white;
    border: none;
    padding: 16px 22px;
    cursor: pointer;
    font-size: 15px;
    white-space: nowrap;
}

.top-tabs button:hover {
    background: #0067b1;
}

.top-tabs button.active {
    background: #00a3e0;
    font-weight: bold;
}

.content {
    padding: 20px;
}

.card {
    background: white;
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.summary {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
}

.summary-card {
    flex: 1;
    min-width: 180px;
    background: white;
    padding: 20px;
    border-left: 6px solid #00a3e0;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.summary-card h3 {
    margin: 0;
    color: #0067b1;
}

.badge-pass {
    background: #16a34a;
    color: white;
    padding: 6px 12px;
    border-radius: 20px;
}

.badge-fail {
    background: #dc2626;
    color: white;
    padding: 6px 12px;
    border-radius: 20px;
}

pre {
    background: #111827;
    color: #d1fae5;
    padding: 20px;
    border-radius: 8px;
    overflow-x: auto;
    white-space: pre-wrap;
    font-size: 14px;
}

.tab-content {
    display: none;
}

.tab-content.active {
    display: block;
}

.action-buttons {
    margin-bottom: 15px;
}

.action-buttons button {
    background: #0067b1;
    color: white;
    border: none;
    padding: 10px 16px;
    margin-right: 8px;
    border-radius: 5px;
    cursor: pointer;
}

.action-buttons button:hover {
    background: #004f87;
}

.error {
    color: #dc2626;
    font-weight: bold;
}

.success {
    color: #16a34a;
    font-weight: bold;
}
</style>

<script>
function openTab(tabName) {
    var contents = document.getElementsByClassName("tab-content");
    for (var i = 0; i < contents.length; i++) {
        contents[i].classList.remove("active");
    }

    var buttons = document.getElementsByClassName("tab-button");
    for (var j = 0; j < buttons.length; j++) {
        buttons[j].classList.remove("active");
    }

    document.getElementById(tabName).classList.add("active");
    document.getElementById("btn-" + tabName).classList.add("active");
}

function printReport() {
    window.print();
}

function showErrorsOnly() {
    var blocks = document.getElementsByClassName("command-block");
    for (var i = 0; i < blocks.length; i++) {
        var status = blocks[i].getAttribute("data-status");
        if (status === "success") {
            blocks[i].style.display = "none";
        }
    }
}

function showAll() {
    var blocks = document.getElementsByClassName("command-block");
    for (var i = 0; i < blocks.length; i++) {
        blocks[i].style.display = "block";
    }
}
</script>

</head>

<body>

<div class="header">
    <div>
        <h1>NetApp ONTAP Health Check Report</h1>
        <div class="header-info">
            Cluster: {{ hostname }} |
            Report Type: HEALTH CHECK |
            Generated: {{ report_time }}
        </div>
    </div>

    <div class="action-buttons">
        <button onclick="printReport()">Print / Save PDF</button>
        <button onclick="showErrorsOnly()">Show Errors Only</button>
        <button onclick="showAll()">Show All</button>
    </div>
</div>

<div class="content">

    <div class="summary">
        <div class="summary-card">
            <h3>Cluster IP</h3>
            <p>{{ hostname }}</p>
        </div>

        <div class="summary-card">
            <h3>Total Checks</h3>
            <p>{{ ontap_results.results | length }}</p>
        </div>

        <div class="summary-card">
            <h3>Completed</h3>
            <p class="success">
                {{ ontap_results.results | selectattr('rc', 'equalto', 0) | list | length }}
            </p>
        </div>

        <div class="summary-card">
            <h3>Failed</h3>
            <p class="error">
                {{ ontap_results.results | rejectattr('rc', 'equalto', 0) | list | length }}
            </p>
        </div>
    </div>

</div>

<div class="top-tabs">
{% for result in ontap_results.results %}
    {% set clean_tab = result.item.tab | replace(' ', '_') %}
    <button
        class="tab-button {% if loop.first %}active{% endif %}"
        id="btn-{{ clean_tab }}"
        onclick="openTab('{{ clean_tab }}')">
        {{ result.item.tab }}
    </button>
{% endfor %}
</div>

<div class="content">

{% for result in ontap_results.results %}
    {% set clean_tab = result.item.tab | replace(' ', '_') %}

    <div
        id="{{ clean_tab }}"
        class="tab-content {% if loop.first %}active{% endif %}">

        <div
            class="card command-block"
            data-status="{% if result.rc == 0 %}success{% else %}failed{% endif %}">

            <h2>{{ result.item.tab }}</h2>

            <p>
                <b>Command:</b>
                <code>{{ result.item.command }}</code>
            </p>

            <p>
                <b>Status:</b>
                {% if result.rc == 0 %}
                    <span class="badge-pass">SUCCESS</span>
                {% else %}
                    <span class="badge-fail">FAILED</span>
                {% endif %}
            </p>

            <h3>Output</h3>

            {% if result.stdout is defined and result.stdout | length > 0 %}
                <pre>{{ result.stdout }}</pre>
            {% elif result.stderr is defined and result.stderr | length > 0 %}
                <pre>{{ result.stderr }}</pre>
            {% else %}
                <pre>No output received.</pre>
            {% endif %}

        </div>

    </div>

{% endfor %}

</div>

</body>
</html>
