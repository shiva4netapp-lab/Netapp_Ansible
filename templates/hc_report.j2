function searchCurrentTab() {
    var activePanel = document.querySelector(".tab-panel.active");

    if (!activePanel) {
        return;
    }

    var input = activePanel.querySelector(".search-input");
    var output = activePanel.querySelector(".output-box");

    if (!input || !output) {
        return;
    }

    var filter = input.value.toLowerCase();
    var original = output.getAttribute("data-original");

    if (!original) {
        output.setAttribute("data-original", output.innerText);
        original = output.innerText;
    }

    if (filter === "") {
        output.innerText = original;
        return;
    }

    var lines = original.split("\n");
    var matched = [];

    for (var i = 0; i < lines.length; i++) {
        if (lines[i].toLowerCase().indexOf(filter) !== -1) {
            matched.push(lines[i]);
        }
    }

    output.innerText = matched.join("\n");
}

/* GLOBAL SEARCH FUNCTIONS */
function escapeSearchHtml(value) {
    return value
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
}

function highlightGlobalSearchMatch(line, keyword) {
    var safeLine = escapeSearchHtml(line);

    if (!keyword) {
        return safeLine;
    }

    var escapedKeyword = keyword.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    var regex = new RegExp("(" + escapedKeyword + ")", "gi");

    return safeLine.replace(
        regex,
        '<span class="search-highlight">$1</span>'
    );
}

function setGlobalSearch(value) {
    var input = document.getElementById("globalSearchInput");

    if (input) {
        input.value = value;
        globalSearchAllCommands();
    }
}

function clearGlobalSearch() {
    var input = document.getElementById("globalSearchInput");
    var results = document.getElementById("globalSearchResults");

    if (input) {
        input.value = "";
    }

    if (results) {
        results.innerHTML = "";
    }
}

function globalSearchAllCommands() {
    var input = document.getElementById("globalSearchInput");
    var results = document.getElementById("globalSearchResults");

    if (!input || !results) {
        return;
    }

    var keyword = input.value.trim();
    var searchText = keyword.toLowerCase();

    results.innerHTML = "";

    if (searchText.length === 0) {
        results.innerHTML =
            '<div class="global-search-summary">Enter text to search across all command outputs.</div>';
        return;
    }

    var commandHeaders = document.querySelectorAll(".command-header");
    var totalCommandMatches = 0;
    var totalLineMatches = 0;
    var renderedKeys = {};

    for (var i = 0; i < commandHeaders.length; i++) {
        var commandHeader = commandHeaders[i];
        var commandName = commandHeader.innerText.trim();
        var outputBox = commandHeader.nextElementSibling;

        if (!outputBox || !outputBox.classList.contains("output-box")) {
            continue;
        }

        var outputText = outputBox.innerText || "";
        var lines = outputText.split("\n");
        var matchedLines = [];

        for (var j = 0; j < lines.length; j++) {
            if (lines[j].toLowerCase().indexOf(searchText) !== -1) {
                matchedLines.push(lines[j]);
            }
        }

        if (matchedLines.length > 0) {
            var uniqueKey = commandName + "::" + matchedLines.join("|");

            if (renderedKeys[uniqueKey]) {
                continue;
            }

            renderedKeys[uniqueKey] = true;

            totalCommandMatches++;
            totalLineMatches += matchedLines.length;

            var highlightedLines = [];

            for (var k = 0; k < matchedLines.length; k++) {
                highlightedLines.push(
                    highlightGlobalSearchMatch(matchedLines[k], keyword)
                );
            }

            results.innerHTML +=
                '<div class="search-result-card">' +
                '<h3>' + escapeSearchHtml(commandName) + '</h3>' +
                '<pre>' + highlightedLines.join("\n") + '</pre>' +
                '</div>';
        }
    }

    if (totalCommandMatches === 0) {
        results.innerHTML =
            '<div class="global-search-summary">No results found for: <b>' +
            escapeSearchHtml(keyword) +
            '</b></div>';
    } else {
        results.innerHTML =
            '<div class="global-search-summary">Search Results for "<b>' +
            escapeSearchHtml(keyword) +
            '</b>" - Found in ' +
            totalCommandMatches +
            ' command(s), ' +
            totalLineMatches +
            ' matching line(s)</div>' +
            results.innerHTML;
    }
}

window.onload = function() {
    openMainTab("cluster_checks_panel");
}
</script>
