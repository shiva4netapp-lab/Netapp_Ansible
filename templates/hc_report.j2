<!DOCTYPE html>
<html>
<head>
<title>NetApp ONTAP Health Check Report</title>

<style>
* {
    box-sizing: border-box;
}

body {
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    background: #f4f7fb;
    color: #1f2937;
}

.header {
    background: #ffffff;
    padding: 24px 30px;
    border-bottom: 4px solid #0067b1;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.header-left h1 {
    margin: 0;
    color: #0067b1;
    font-size: 38px;
    font-weight: 700;
}

.header-left p {
    margin: 5px 0 0 0;
    color: #4b5563;
    font-size: 16px;
}

.header-buttons button {
    background: #0067b1;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 14px 22px;
    font-size: 15px;
    cursor: pointer;
    margin-left: 10px;
}

.header-buttons button:hover {
    background: #004f87;
}

.summary {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
    padding: 30px;
}

.summary-card {
    background: #ffffff;
    border-left: 7px solid #00a3e0;
    border-radius: 9px;
    padding: 26px 30px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.08);
    min-height: 125px;
}

.summary-card h2 {
    margin: 0;
    color: #0067b1;
    font-size: 22px;
}

.summary-card p {
    font-size: 22px;
    margin-bottom: 0;
}

.pass-text {
    color: #16a34a;
    font-weight: bold;
}

.fail-text {
    color: #dc2626;
    font-weight: bold;
}

.warn-text {
    color: #d97706;
    font-weight: bold;
}

.main-tabs-wrapper {
    margin: 0 30px;
    border: 3px solid #214f9c;
    border-radius: 10px;
    overflow-x: auto;
    background: #eef3f8;
}

.main-tabs {
    display: flex;
    min-width: max-content;
}

.main-tab {
    padding: 18px 25px;
    color: #003b7a;
    font-weight: bold;
    position: relative;
}

.main-tab.active {
    background: #214f9c;
    color: white;
}

.tabs-wrapper {
    margin: 16px 30px 0 30px;
    background: #26384f;
    overflow-x: auto;
    white-space: nowrap;
    border-radius: 8px;
}

.tabs {
    display: flex;
    min-width: max-content;
}

.tab-button {
    background: #26384f;
    color: white;
    border: none;
    padding: 20px 24px;
    cursor: pointer;
    font-size: 16px;
    font-weight: bold;
    border-right: 1px solid rgba(255,255,255,0.08);
    position: relative;
}

.tab-button:hover {
    background: #0067b1;
}

.tab-button.active {
    background: #00a3e0;
    font-weight: bold;
}

.error-badge {
    background: #ef3340;
    color: white;
    border-radius: 50%;
    padding: 5px 9px;
    font-size: 12px;
    font-weight: bold;
    margin-left: 6px;
    display: inline-block;
    min-width: 25px;
    text-align: center;
}

.big-error-badge {
    background: #ef3340;
    color: white;
    border-radius: 18px;
    padding: 6px 12px;
    font-size: 14px;
    font-weight: bold;
    margin-left: 8px;
}

.error-popup {
    display: none;
    position: absolute;
    top: 52px;
    left: 10px;
    background: white;
    color: #1f2937;
    border: 2px solid #ef3340;
    border-radius: 8px;
    min-width: 340px;
    max-width: 520px;
    padding: 14px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.25);
    z-index: 9999;
    text-align: left;
    font-size: 13px;
    white-space: normal;
}

.tab-button:hover .error-popup {
    display: block;
}

.popup-title {
    color: #dc2626;
    font-weight: bold;
    margin-bottom: 8px;
}

.popup-line {
    border-bottom: 1px solid #e5e7eb;
    padding: 5px 0;
}

.content {
    padding: 28px 30px;
}

.tab-panel {
    display: none;
}

.tab-panel.active {
    display: block;
}

.section-title {
    background: #8fd2ee;
    color: #005a9c;
    text-align: center;
    padding: 20px;
    font-size: 34px;
    font-weight: bold;
    border-radius: 6px;
    margin-bottom: 25px;
}

.card {
    background: #ffffff;
    border-radius: 8px;
    margin-bottom: 22px;
    padding: 22px;
    box-shadow: 0 3px 12px rgba(0,0,0,0.08);
}

.card h2 {
    margin-top: 0;
    color: #0067b1;
}

.status-badge {
    display: inline-block;
    color: white;
    border-radius: 20px;
    padding: 8px 16px;
    font-weight: bold;
    font-size: 13px;
}

.status-success {
    background: #16a34a;
}

.status-warning {
    background: #d97706;
}

.status-failed {
    background: #dc2626;
}

.status-info {
    background: #22c55e;
    color: white;
    display: inline-block;
    padding: 14px 20px;
    border-radius: 6px;
    font-size: 22px;
    font-weight: bold;
}

.criteria {
    background: #f8fafc;
    border-left: 5px solid #0067b1;
    padding: 15px;
    border-radius: 5px;
}

.criteria ul {
    margin: 8px 0 0 20px;
}

.command-box {
    background: #eef6ff;
    border-left: 5px solid #00a3e0;
    padding: 14px;
    border-radius: 5px;
    margin-bottom: 15px;
}

.output-box {
    background: #111827;
    color: #d1fae5;
    padding: 20px;
    border-radius: 8px;
    overflow-x: auto;
    white-space: pre-wrap;
    font-size: 14px;
    line-height: 1.5;
    min-height: 90px;
}

.error-output-box {
    background: #3b0a0a;
    color: #fecaca;
    padding: 20px;
    border-radius: 8px;
    overflow-x: auto;
    white-space: pre-wrap;
    font-size: 14px;
    line-height: 1.5;
}

.table-like {
    width: 100%;
    border-collapse: collapse;
    margin-top: 15px;
}

.table-like th {
    background: #0067b1;
    color: white;
    text-align: left;
    padding: 12px;
}

.table-like td {
    padding: 12px;
    border-bottom: 1px solid #e5e7eb;
}

.search-box {
    margin-bottom: 15px;
}

.search-box input {
    width: 320px;
    padding: 10px;
    border: 1px solid #cbd5e1;
    border-radius: 5px;
    font-size: 14px;
}

.hidden-by-error-filter {
    display: none !important;
}

.footer {
    text-align: center;
    color: #6b7280;
    padding: 25px;
    font-size: 13px;
}

@media print {
    .header-buttons,
    .main-tabs-wrapper,
    .tabs-wrapper,
    .search-box {
        display: none;
    }

    .tab-panel {
        display: block !important;
        page-break-after: always;
    }

    body {
        background: white;
    }
}

@media screen and (max-width: 900px) {
    .summary {
        grid-template-columns: repeat(2, 1fr);
    }

    .header {
        display: block;
    }

    .header-buttons {
        margin-top: 20px;
    }
}

@media screen and (max-width: 600px) {
    .summary {
        grid-template-columns: 1fr;
    }
}
</style>

<script>
function openTab(tabId) {
    var panels = document.getElementsByClassName("tab-panel");
    for (var i = 0; i < panels.length; i++) {
        panels[i].classList.remove("active");
    }

    var buttons = document.getElementsByClassName("tab-button");
    for (var j = 0; j < buttons.length; j++) {
        buttons[j].classList.remove("active");
    }

    document.getElementById(tabId).classList.add("active");
    document.getElementById("btn-" + tabId).classList.add("active");
}

function showErrorsOnly() {
    var panels = document.getElementsByClassName("tab-panel");
    for (var i = 0; i < panels.length; i++) {
        var errorCount = parseInt(panels[i].getAttribute("data-error-count"));
        if (errorCount === 0) {
            panels[i].classList.add("hidden-by-error-filter");
        } else {
            panels[i].classList.remove("hidden-by-error-filter");
        }
    }
}

function showAll() {
    var panels = document.getElementsByClassName("tab-panel");
    for (var i = 0; i < panels.length; i++) {
        panels[i].classList.remove("hidden-by-error-filter");
    }
}

function searchCurrentTab() {
    var activePanel = document.querySelector(".tab-panel.active");
    if (!activePanel) {
        return;
    }

    var input = activePanel.querySelector(".search-input");
    var output = activePanel.querySelector(".output-box");
    if (!input || !output) {
        return;
    }

    var filter = input.value.toLowerCase();
    var original = output.getAttribute("data-original");

    if (!original) {
        output.setAttribute("data-original", output.innerText);
        original = output.innerText;
    }

    if (filter === "") {
        output.innerText = original;
        return;
    }

    var lines = original.split("\n");
    var matched = [];

    for (var i = 0; i < lines.length; i++) {
        if (lines[i].toLowerCase().indexOf(filter) !== -1) {
            matched.push(lines[i]);
        }
    }

    output.innerText = matched.join("\n");
}

window.onload = function() {
    var firstButton = document.querySelector(".tab-button");
    if (firstButton) {
        firstButton.click();
    }
}
</script>

</head>

<body>

{% set total_checks = ontap_results.results | length %}

{% set total_error_ns = namespace(count=0) %}

{% for result in ontap_results.results %}
    {% set tab_error_ns = namespace(count=0) %}

    {% if result.rc != 0 %}
        {% set tab_error_ns.count = tab_error_ns.count + 1 %}
    {% endif %}

    {% if result.stdout_lines is defined %}
        {% for line in result.stdout_lines %}
            {% set l = line | lower %}
            {% if
                'false' in l or
                'fail' in l or
                'failed' in l or
                'error' in l or
                'offline' in l or
                'down' in l or
                'degraded' in l or
                'not-configured' in l or
                'unknown' in l or
                'unhealthy' in l
            %}
                {% set tab_error_ns.count = tab_error_ns.count + 1 %}
            {% endif %}
        {% endfor %}
    {% endif %}

    {% if result.stderr_lines is defined %}
        {% for line in result.stderr_lines %}
            {% set l = line | lower %}
            {% if
                'error' in l or
                'failed' in l or
                'not recognized' in l or
                'no route' in l or
                'permission denied' in l or
                'connection refused' in l
            %}
                {% set tab_error_ns.count = tab_error_ns.count + 1 %}
            {% endif %}
        {% endfor %}
    {% endif %}

    {% set total_error_ns.count = total_error_ns.count + tab_error_ns.count %}
{% endfor %}

{% set failed_checks = total_error_ns.count %}
{% set success_checks = total_checks - (ontap_results.results | rejectattr('rc', 'equalto', 0) | list | length) %}

<div class="header">
    <div class="header-left">
        <h1>NetApp ONTAP Health Check Report</h1>
        <p>
            Cluster: {{ hostname }} |
            Report Type: HEALTH CHECK |
            Generated: {{ report_time }}
        </p>
    </div>

    <div class="header-buttons">
        <button onclick="window.print()">Print / Save PDF</button>
        <button onclick="showErrorsOnly()">Show Errors Only</button>
        <button onclick="showAll()">Show All</button>
    </div>
</div>

<div class="summary">
    <div class="summary-card">
        <h2>Cluster IP</h2>
        <p>{{ hostname }}</p>
    </div>

    <div class="summary-card">
        <h2>Total Checks</h2>
        <p>{{ total_checks }}</p>
    </div>

    <div class="summary-card">
        <h2>Completed</h2>
        <p class="pass-text">{{ success_checks }}</p>
    </div>

    <div class="summary-card">
        <h2>Error Count</h2>
        <p class="fail-text">{{ failed_checks }}</p>
    </div>
</div>

<div class="main-tabs-wrapper">
    <div class="main-tabs">
        <div class="main-tab active">
            ONTAP Cluster Checks
            {% if failed_checks > 0 %}
                <span class="big-error-badge">{{ failed_checks }}</span>
            {% endif %}
        </div>
        <div class="main-tab">Package Validation</div>
        <div class="main-tab">SSH Command Output</div>
    </div>
</div>

<div class="tabs-wrapper">
    <div class="tabs">

        {% for result in ontap_results.results %}
            {% set tab_id = result.item.tab | replace(' ', '_') | replace('/', '_') %}

            {% set tab_error_ns = namespace(count=0, popup='') %}

            {% if result.rc != 0 %}
                {% set tab_error_ns.count = tab_error_ns.count + 1 %}
                {% set tab_error_ns.popup = tab_error_ns.popup ~ 'Return code is ' ~ result.rc ~ '\n' %}
            {% endif %}

            {% if result.stdout_lines is defined %}
                {% for line in result.stdout_lines %}
                    {% set l = line | lower %}
                    {% if
                        'false' in l or
                        'fail' in l or
                        'failed' in l or
                        'error' in l or
                        'offline' in l or
                        'down' in l or
                        'degraded' in l or
                        'not-configured' in l or
                        'unknown' in l or
                        'unhealthy' in l
                    %}
                        {% set tab_error_ns.count = tab_error_ns.count + 1 %}
                        {% set tab_error_ns.popup = tab_error_ns.popup ~ line ~ '\n' %}
                    {% endif %}
                {% endfor %}
            {% endif %}

            {% if result.stderr_lines is defined %}
                {% for line in result.stderr_lines %}
                    {% set l = line | lower %}
                    {% if
                        'error' in l or
                        'failed' in l or
                        'not recognized' in l or
                        'no route' in l or
                        'permission denied' in l or
                        'connection refused' in l
                    %}
                        {% set tab_error_ns.count = tab_error_ns.count + 1 %}
                        {% set tab_error_ns.popup = tab_error_ns.popup ~ line ~ '\n' %}
                    {% endif %}
                {% endfor %}
            {% endif %}

            <button
                id="btn-{{ tab_id }}"
                class="tab-button"
                onclick="openTab('{{ tab_id }}')">

                {{ result.item.tab }}

                {% if tab_error_ns.count > 0 %}
                    <span class="error-badge">{{ tab_error_ns.count }}</span>

                    <div class="error-popup">
                        <div class="popup-title">
                            {{ result.item.tab }} - {{ tab_error_ns.count }} issue(s)
                        </div>

                        {% for popup_line in tab_error_ns.popup.split('\n') %}
                            {% if popup_line | length > 0 %}
                                <div class="popup-line">{{ popup_line }}</div>
                            {% endif %}
                        {% endfor %}
                    </div>
                {% endif %}
            </button>
        {% endfor %}

    </div>
</div>

<div class="content">

{% for result in ontap_results.results %}
    {% set tab_id = result.item.tab | replace(' ', '_') | replace('/', '_') %}

    {% set tab_error_ns = namespace(count=0) %}

    {% if result.rc != 0 %}
        {% set tab_error_ns.count = tab_error_ns.count + 1 %}
    {% endif %}

    {% if result.stdout_lines is defined %}
        {% for line in result.stdout_lines %}
            {% set l = line | lower %}
            {% if
                'false' in l or
                'fail' in l or
                'failed' in l or
                'error' in l or
                'offline' in l or
                'down' in l or
                'degraded' in l or
                'not-configured' in l or
                'unknown' in l or
                'unhealthy' in l
            %}
                {% set tab_error_ns.count = tab_error_ns.count + 1 %}
            {% endif %}
        {% endfor %}
    {% endif %}

    {% if result.stderr_lines is defined %}
        {% for line in result.stderr_lines %}
            {% set l = line | lower %}
            {% if
                'error' in l or
                'failed' in l or
                'not recognized' in l or
                'no route' in l or
                'permission denied' in l or
                'connection refused' in l
            %}
                {% set tab_error_ns.count = tab_error_ns.count + 1 %}
            {% endif %}
        {% endfor %}
    {% endif %}

    <div
        id="{{ tab_id }}"
        class="tab-panel"
        data-error-count="{{ tab_error_ns.count }}">

        <div class="section-title">
            {{ result.item.tab }}
        </div>

        <div class="card">
            <h2>{{ result.item.tab }}</h2>

            {% if tab_error_ns.count > 0 %}
                <div class="status-info" style="background:#dc2626;">
                    Status: Review Required - {{ tab_error_ns.count }} Issue(s)
                </div>
            {% elif result.rc == 0 %}
                <div class="status-info">
                    Status: Info
                </div>
            {% else %}
                <div class="status-info" style="background:#d97706;">
                    Status: Warning
                </div>
            {% endif %}
        </div>

        <div class="card">
            <h2>Error Criteria</h2>

            <div class="criteria">
                <ul>
                    {% for criteria in result.item.error_criteria %}
                        <li>{{ criteria }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>

        <div class="card">
            <h2>Check Summary</h2>

            <table class="table-like">
                <tr>
                    <th>Check Category</th>
                    <th>Command</th>
                    <th>Status</th>
                    <th>Error Count</th>
                    <th>Return Code</th>
                </tr>

                <tr>
                    <td>{{ result.item.category }}</td>
                    <td>{{ result.item.command }}</td>
                    <td>
                        {% if tab_error_ns.count > 0 %}
                            <span class="status-badge status-failed">REVIEW</span>
                        {% elif result.rc == 0 %}
                            <span class="status-badge status-success">SUCCESS</span>
                        {% else %}
                            <span class="status-badge status-warning">WARNING</span>
                        {% endif %}
                    </td>
                    <td>{{ tab_error_ns.count }}</td>
                    <td>{{ result.rc }}</td>
                </tr>
            </table>
        </div>

        <div class="card">
            <h2>Command Output</h2>

            <div class="command-box">
                <b>Executed Command:</b> {{ result.item.command }}
            </div>

            <div class="search-box">
                <input
                    class="search-input"
                    type="text"
                    placeholder="Search output in this tab"
                    onkeyup="searchCurrentTab()">
            </div>

            {% if result.stdout is defined and result.stdout | length > 0 %}
                <pre class="output-box">{{ result.stdout }}</pre>
            {% else %}
                <pre class="output-box">No output received.</pre>
            {% endif %}
        </div>

        {% if result.stderr is defined and result.stderr | length > 0 %}
        <div class="card">
            <h2>SSH Warning / Error Output</h2>
            <pre class="error-output-box">{{ result.stderr }}</pre>
        </div>
        {% endif %}

    </div>

{% endfor %}

</div>

<div class="footer">
    Generated by Ansible Forms | NetApp ONTAP Health Check Report
</div>

</body>
</html>
